{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "target": "ESNext",
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@features/*": ["./src/renderer/src/features/*"],
      "@widgets/*": ["./src/renderer/src/widgets/*"],
      "@entities/*": ["./src/renderer/src/entities/*"],
      "@shared/*": ["./src/renderer/src/shared/*"]
    }
  },
  "include": ["src/renderer/**/*"]
}
